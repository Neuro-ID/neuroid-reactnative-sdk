{
  "name": "neuroid-reactnative-sdk",
  "version": "4.0.0",
  "description": "Official NeuroID React Native SDK",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "neuroid-reactnative-sdk.podspec",
    "!lib/typescript/example",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "format:check": "prettier --check ./src ./tests package*.json",
    "format:fix": "prettier --write ./src ./tests *.js package*.json",
    "lint:check": "eslint ./src ./tests *.js",
    "lint:fix": "eslint --fix ./src ./tests *.js",
    "prepare": "bob build && husky",
    "typecheck": "tsc --noEmit",
    "bootstrap": "yarn"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neuro-ID/neuroid-reactnative-sdk.git"
  },
  "author": "NeuroID <engineering@neuro-id.com> (https://github.com/Neuro-ID/neuroid-reactnative-sdk)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Neuro-ID/neuroid-reactnative-sdk/issues"
  },
  "homepage": "https://github.com/Neuro-ID/neuroid-reactnative-sdk#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.5",
    "@types/react": "^18.2.24",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.2",
    "husky": "9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "react": "18.2.0",
    "react-native": "0.76.0",
    "react-native-builder-bob": "^0.18.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.76.0"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{ts,tsx,json}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "trailingComma": "es5"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
